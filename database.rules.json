{
  "rules": {
    "games": {
      "$gameId": {
        ".read": "true",
        ".write": "data.child('hostUid').val() == auth.uid || !data.exists()",

        "hostUid": { 
          ".validate": "!data.exists() && newData.exists()" 
        },
        "gameId": {
          ".validate": "!data.exists() && newData.exists() && newData.val() == $gameId"
        },

        "currentQuestion": {
          ".write": "data.parent().child('currentQuerentId').val() == auth.uid"
        },
        "questionStatus": {
          ".write": "data.parent().child('currentQuerentId').val() == auth.uid"
        },
        
        "players": {
          "$playerId": {
             ".write": "auth.uid == $playerId && !data.exists()"
          }
        },
        
        "submissions": {
          "$playerId": {
            ".write": "auth.uid == $playerId"
          }
        }
      }
    }
  }
}
